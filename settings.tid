<$list filter="[all[tiddlers+shadows]tag[$:/tags/NamespaceAlias]]" emptyMessage="<em>none defined</em>">
* <code><$view field="short"/></code> → <code><$view field="expands-to"/></code> &nbsp;<span style="opacity:0.7;">(<$link to=<<currentTiddler>>>source</$link>)</span>
</$list>

